NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/procurement_dev
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-at-least-32-character-random-string
JWT_REFRESH_SECRET=replace-with-different-32-character-random-string
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_ATTEMPTS=5
SUPPLIER_LINK_EXPIRY_HOURS=72
SUPPLIER_LINK_SECRET=replace-with-at-least-32-character-random-string
LOG_LEVEL=info
