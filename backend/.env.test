# Server
PORT=3001
NODE_ENV=test

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/procurement_test

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=test-jwt-secret-for-testing-only
JWT_REFRESH_SECRET=test-refresh-secret-for-testing-only
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Bcrypt (lower rounds for faster tests)
BCRYPT_ROUNDS=4

# Rate Limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_ATTEMPTS=5

# Supplier Link
SUPPLIER_LINK_EXPIRY_HOURS=72
SUPPLIER_LINK_SECRET=test-supplier-link-secret

# Logging
LOG_LEVEL=error
